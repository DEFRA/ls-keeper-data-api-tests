{
  "name": "ls-keeper-data-api-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "engines": {
    "node": ">=22.13.1"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "aliases": {
    "~": "."
  },
  "scripts": {
    "clean": "rm -rf allure-report && rm -rf test-results",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:github": "playwright test",
    "format": "prettier --write '**/*.{js,ts,md,json,config.js}'",
    "format:check": "prettier --check '**/*.{js,ts,md,json,config.js}'",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --fix --no-error-on-unmatched-pattern",
    "postinstall": "npm run setup:husky",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "report": "echo 'Report already generated by Playwright'",
    "report:publish": "npm run report && ./bin/publish-tests.sh"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.1.7",
    "prettier": "3.4.2",
    "typescript": "6.0.3"
  }
}
